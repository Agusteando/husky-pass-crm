{"file":"historial-accesos-wy8BTsrq.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;AAuIA,UAAM,QAAQ,SAAA;AACC,cAAA;AACf,UAAM,YAAY,IAAI,WAAW,MAAM,MAAM,SAAS,CAAC;AACvD,UAAM,UAAU,IAAI,WAAW,MAAM,MAAM,OAAO,CAAC;AACnD,UAAM,UAAU,IAAI,WAAW,MAAM,MAAM,OAAO,CAAC;AACnD,UAAM,SAAS,IAAI,WAAW,MAAM,MAAM,MAAM,CAAC;AAGjD,UAAM,QAAQ,SAAS,OAAO;AAAA,MAC5B,WAAW,UAAU,SAAS;AAAA,MAC9B,SAAS,QAAQ,SAAS;AAAA,MAC1B,SAAS,QAAQ,SAAS;AAAA,MAC1B,QAAQ,OAAO,SAAS;AAAA,MACxB,OAAO;AAAA,IAAA,EACP;AAEF,UAAM,EAAE,MAAM,SAAS,OAAO,WAAW,QAAA,IAAY,SAAqC,6BAA6B;AAAA,MACrH;AAAA,MACA,OAAO,CAAC,KAAK;AAAA,MACb,SAAS;AAAA,MACT,KAAK;AAAA,IAAA,CACN;AAED,UAAM,aAAa,SAAS,MAAM;AAChC,UAAI,CAAC,KAAK,MAAO,QAAO;AACxB,aAAO,GAAG,UAAU,KAAK,MAAM,MAAM,SAAS,CAAC,MAAM,UAAU,KAAK,MAAM,MAAM,OAAO,CAAC;AAAA,IAC1F,CAAC;AAED,UAAM,aAAa,SAAS,MAAM;AAChC,YAAM,SAAS,IAAI,gBAAA;AACnB,UAAI,UAAU,MAAO,QAAO,IAAI,aAAa,UAAU,KAAK;AAC5D,UAAI,QAAQ,MAAO,QAAO,IAAI,WAAW,QAAQ,KAAK;AACtD,UAAI,QAAQ,MAAO,QAAO,IAAI,WAAW,QAAQ,KAAK;AACtD,UAAI,OAAO,MAAO,QAAO,IAAI,UAAU,OAAO,KAAK;AACnD,aAAO,IAAI,SAAS,MAAM;AAC1B,aAAO,oCAAoC,OAAO,SAAA,CAAU;AAAA,IAC9D,CAAC;AAED,aAAS,WAAW,OAAgB;AAClC,UAAI,MAAM,QAAQ,KAAK,EAAG,QAAO,OAAO,MAAM,CAAC,KAAK,EAAE,EAAE,KAAA;AACxD,aAAO,OAAO,SAAS,EAAE,EAAE,KAAA;AAAA,IAC7B;AAgBA,aAAS,UAAU,MAAc;AAC/B,aAAO,qBAAqB,IAAI;AAAA,IAClC;AAEA,aAAS,UAAU,MAAc;AAC/B,aAAO,qBAAqB,MAAM,OAAO;AAAA,IAC3C;AAEA,aAAS,SAAS,MAAc;AAC9B,aAAO,KAAK,MAAM,KAAK,EAAE,OAAO,OAAO,EAAE,MAAM,GAAG,CAAC,EAAE,IAAI,CAAC,SAAS,KAAK,CAAC,GAAG,aAAa,EAAE,KAAK,EAAE,KAAK;AAAA,IACzG;;;;;QAzMW,OAAM;AAAA,QAAqB,qBAAkB;AAAA,MAAA,gYAQlBA,cAAA,QAAM,WAAA,KAAU,mRAEWC,MAAA,OAAA,CAAO,IAAA,cAAA,iFAC3DA,MAAA,OAAA,IAAO,oBAAA,YAAA,wJAQI,UAAA,KAAS,sKAIT,QAAA,KAAO,4RAIN,QAAA,KAAO,oBAAP,QAAA,OAAO,EAAA,kBAAP,QAAA,OAAO,EAAA,CAAA,IAAA,cAAA;oBAEGA,MAAA,IAAA,GAAM,aAAS,CAAA,GAAA,CAAzB,WAAM;wBAA0CD,cAAA,SAAO,MAAM,wDAF7D,QAAA,KAAO,IAAPE,gBAAA,QAAA,OAEuD,MAAM,IAF7DC,cAAA,QAAA,OAEuD,MAAM,CAAA,IAAA,cAAA,qBAAK,MAAM;;+HAM9E,OAAA,KAAM,CAAA,8JAAA;UAUNF,MAAA,IAAA,GAAI;+JACoBA,MAAA,IAAA,EAAK,QAAQ,IAAI,4HACbA,MAAA,IAAA,EAAK,QAAQ,OAAO,2HACrBA,MAAA,IAAA,EAAK,QAAQ,KAAK,2HAClBA,MAAA,IAAA,EAAK,QAAQ,QAAQ,4HACpBA,MAAA,IAAA,EAAK,QAAQ,YAAY;;;;UAG3DA,MAAA,SAAA,GAAS;;MACF,WAAAA,MAAA,OAAA,MAAYA,MAAA,IAAA,GAAI;;iBAEZA,MAAA,IAAA,GAAM,KAAK,QAAM;kSAIP,WAAA,KAAU,2CACzBA,MAAA,IAAA,EAAK,KAAK,MAAM,yFAEFA,MAAA,IAAA,EAAK,QAAQ,KAAK;sBAenBA,MAAA,IAAA,EAAK,MAAI,CAAhB,QAAG;sHAEC,IAAI,QAAQ,IAAI,oCACjBG,eAAAH,MAAA,gBAAA,EAAiB,IAAI,QAAQ,SAAS,CAAA,uBAAW,IAAI,QAAQ,SAAS,IAAI,QAAQ,OAAO,IAAI,QAAQ,KAAK,EAAE,OAAO,OAAO,EAAE,KAAI,KAAA,CAAA,uEAElH,UAAU,IAAI,IAAI,CAAA,yFAE/B,IAAI,SAAS,QAAI,cAAA,oCAClBG,eAAA,IAAI,SAAS,OAAO,QAAI,EAAA,gGAGvB,IAAI,QAAQ,QAAI,cAAA,oCACjBA,eAAA,IAAI,QAAQ,OAAO,QAAI,EAAA,qHAGH,IAAI,OAAO,MAAM;;;sBAY7BH,MAAA,IAAA,EAAK,QAAM,CAArB,WAAM;;AAEkB,cAAA,OAAO,UAAQ;;cAAG,KAAK,OAAO;AAAA,cAAW,WAAS,uBAAyB,OAAO,EAAE;AAAA,cAAK,KAAK,OAAO;AAAA,YAAA;;uDAC5H,SAAS,OAAO,IAAI,CAAA,CAAA,MAAA;AAAA;wEAGtBG,eAAA,OAAO,IAAI,oCACZA,eAAA,OAAO,cAAU,oBAAA;;;iBAOrBH,MAAA,IAAA,GAAI;;;UACN,OAAM;AAAA,UAAc,aAAY;AAAA,QAAA;;;;;;;;;;;;;;;;","names":["_ssrRenderAttr","_unref","_ssrLooseContain","_ssrLooseEqual","_ssrInterpolate"],"sources":["../../../../pages/admin/historial-accesos.vue"],"sourcesContent":["<template>\n  <section class=\"access-admin stack\" data-product-area=\"admin-access-history\">\n    <header class=\"workspace-head compact-head access-head\">\n      <div>\n        <p class=\"eyebrow\">Personas Autorizadas</p>\n        <h1>Historial de accesos</h1>\n        <p>Consulta entradas y salidas agrupadas por alumno y fecha.</p>\n      </div>\n      <div class=\"head-actions\">\n        <a class=\"btn btn-secondary\" :href=\"exportHref\" data-diagnostic-action=\"exportar-accesos\">Exportar CSV</a>\n        <button class=\"btn btn-secondary\" type=\"button\" data-diagnostic-action=\"imprimir-accesos\" @click=\"printReport\">Imprimir / PDF</button>\n        <button class=\"btn btn-primary\" type=\"button\" :disabled=\"pending\" data-diagnostic-action=\"actualizar-accesos\" @click=\"refreshReport\">\n          {{ pending ? 'Actualizando...' : 'Actualizar' }}\n        </button>\n      </div>\n    </header>\n\n    <section class=\"filters-card card\">\n      <label class=\"label\">\n        Desde\n        <input v-model=\"startDate\" class=\"input\" type=\"date\" data-diagnostic-filter=\"fecha-inicio\" @change=\"syncRoute\" />\n      </label>\n      <label class=\"label\">\n        Hasta\n        <input v-model=\"endDate\" class=\"input\" type=\"date\" data-diagnostic-filter=\"fecha-fin\" @change=\"syncRoute\" />\n      </label>\n      <label class=\"label\">\n        Plantel\n        <select v-model=\"plantel\" class=\"select\" data-diagnostic-filter=\"plantel-accesos\" @change=\"syncRoute\">\n          <option value=\"\">Todos</option>\n          <option v-for=\"option in data?.planteles || []\" :key=\"option\" :value=\"option\">{{ option }}</option>\n        </select>\n      </label>\n      <label class=\"label search-label\">\n        Buscar\n        <input\n          v-model=\"search\"\n          class=\"input\"\n          type=\"search\"\n          placeholder=\"Matrícula, alumno o persona autorizada\"\n          data-diagnostic-filter=\"buscar-accesos\"\n          @input=\"syncRouteDebounced\"\n        />\n      </label>\n    </section>\n\n    <section v-if=\"data\" class=\"metric-grid\">\n      <article><span>Días</span><strong>{{ data.summary.days }}</strong></article>\n      <article><span>Entradas</span><strong>{{ data.summary.entries }}</strong></article>\n      <article><span>Salidas</span><strong>{{ data.summary.exits }}</strong></article>\n      <article><span>Alumnos</span><strong>{{ data.summary.students }}</strong></article>\n      <article><span>Personas</span><strong>{{ data.summary.uniquePeople }}</strong></article>\n    </section>\n\n    <p v-if=\"loadError\" class=\"alert\" data-state=\"error\">No fue posible cargar el historial de accesos.</p>\n    <div v-else-if=\"pending && !data\" class=\"card loading-card\" data-product-loading data-state=\"loading\">Cargando historial...</div>\n\n    <section v-else-if=\"data?.days.length\" class=\"report-layout\" data-product-panel=\"admin-access-history\" data-state=\"content\">\n      <article class=\"card report-card\">\n        <div class=\"section-head\">\n          <div>\n            <p class=\"eyebrow\">{{ rangeLabel }}</p>\n            <h2>{{ data.days.length }} registros consolidados</h2>\n          </div>\n          <span class=\"muted\">{{ data.filters.limit }} eventos máximo</span>\n        </div>\n\n        <div class=\"table-wrap responsive-card-wrap\">\n          <table class=\"table responsive-table access-table\">\n            <thead>\n              <tr>\n                <th>Alumno</th>\n                <th>Fecha</th>\n                <th>Entrada</th>\n                <th>Salida</th>\n                <th>Personas</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"day in data.days\" :key=\"day.key\">\n                <td data-label=\"Alumno\">\n                  <strong>{{ day.student.name }}</strong>\n                  <small>{{ displayMatricula(day.student.matricula) }} · {{ [day.student.plantel, day.student.grado, day.student.grupo].filter(Boolean).join(' / ') }}</small>\n                </td>\n                <td data-label=\"Fecha\">{{ dateLabel(day.date) }}</td>\n                <td data-label=\"Entrada\">\n                  <strong>{{ day.entrada?.time || 'Sin registro' }}</strong>\n                  <small>{{ day.entrada?.person.name || '' }}</small>\n                </td>\n                <td data-label=\"Salida\">\n                  <strong>{{ day.salida?.time || 'Sin registro' }}</strong>\n                  <small>{{ day.salida?.person.name || '' }}</small>\n                </td>\n                <td data-label=\"Personas\">\n                  <span class=\"person-count\">{{ day.people.length }}</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </article>\n\n      <aside class=\"card gallery-card\" data-product-panel=\"admin-access-gallery\">\n        <p class=\"eyebrow\">Galería</p>\n        <h2>Personas autorizadas</h2>\n        <div class=\"gallery-list\">\n          <article v-for=\"person in data.people\" :key=\"person.id\" class=\"gallery-person\">\n            <span class=\"gallery-photo\">\n              <FamilyPersonasProcessedPhoto v-if=\"person.photoUrl\" :src=\"person.photoUrl\" :namespace=\"`admin-access-person-${person.id}`\" :alt=\"person.name\" />\n              <b v-else>{{ initials(person.name) }}</b>\n            </span>\n            <span>\n              <strong>{{ person.name }}</strong>\n              <small>{{ person.parentesco || 'Persona autorizada' }}</small>\n            </span>\n          </article>\n        </div>\n      </aside>\n    </section>\n\n    <div v-else-if=\"data\" data-product-panel=\"admin-access-history\" data-state=\"empty\">\n      <EmptyState title=\"Sin accesos\" description=\"Ajusta fechas, plantel o búsqueda para encontrar registros.\" />\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { useFetch, useRoute, useRouter } from 'nuxt/app'\nimport type { AdminAccessHistoryResponse } from '~/types/accessHistory'\nimport { formatAttendanceDate } from '~/utils/attendance'\nimport { displayMatricula } from '~/utils/matricula'\n\ndefinePageMeta({ layout: 'admin', middleware: ['access-history-admin'] })\n\nconst route = useRoute()\nconst router = useRouter()\nconst startDate = ref(queryValue(route.query.startDate))\nconst endDate = ref(queryValue(route.query.endDate))\nconst plantel = ref(queryValue(route.query.plantel))\nconst search = ref(queryValue(route.query.search))\nlet syncTimer: ReturnType<typeof setTimeout> | null = null\n\nconst query = computed(() => ({\n  startDate: startDate.value || undefined,\n  endDate: endDate.value || undefined,\n  plantel: plantel.value || undefined,\n  search: search.value || undefined,\n  limit: 700\n}))\n\nconst { data, pending, error: loadError, refresh } = useFetch<AdminAccessHistoryResponse>('/api/admin/access-history', {\n  query,\n  watch: [query],\n  timeout: 30000,\n  key: 'admin-access-history'\n})\n\nconst rangeLabel = computed(() => {\n  if (!data.value) return ''\n  return `${shortDate(data.value.range.startDate)} - ${shortDate(data.value.range.endDate)}`\n})\n\nconst exportHref = computed(() => {\n  const params = new URLSearchParams()\n  if (startDate.value) params.set('startDate', startDate.value)\n  if (endDate.value) params.set('endDate', endDate.value)\n  if (plantel.value) params.set('plantel', plantel.value)\n  if (search.value) params.set('search', search.value)\n  params.set('limit', '1000')\n  return `/api/admin/access-history/export?${params.toString()}`\n})\n\nfunction queryValue(value: unknown) {\n  if (Array.isArray(value)) return String(value[0] || '').trim()\n  return String(value || '').trim()\n}\n\nfunction syncRoute() {\n  const next: Record<string, string> = {}\n  if (startDate.value) next.startDate = startDate.value\n  if (endDate.value) next.endDate = endDate.value\n  if (plantel.value) next.plantel = plantel.value\n  if (search.value.trim()) next.search = search.value.trim()\n  router.replace({ path: route.path, query: next })\n}\n\nfunction syncRouteDebounced() {\n  if (syncTimer) clearTimeout(syncTimer)\n  syncTimer = setTimeout(syncRoute, 240)\n}\n\nfunction dateLabel(date: string) {\n  return formatAttendanceDate(date)\n}\n\nfunction shortDate(date: string) {\n  return formatAttendanceDate(date, 'short')\n}\n\nfunction initials(name: string) {\n  return name.split(/\\s+/).filter(Boolean).slice(0, 2).map((part) => part[0]?.toUpperCase()).join('') || 'PA'\n}\n\nfunction printReport() {\n  if (import.meta.client) window.print()\n}\n\nasync function refreshReport() {\n  await refresh()\n}\n</script>\n\n<style scoped>\n.access-admin {\n  gap: 10px;\n}\n\n.access-head {\n  grid-template-columns: minmax(0, 1fr) auto;\n}\n\n.head-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.filters-card {\n  align-items: end;\n  display: grid;\n  gap: 10px;\n  grid-template-columns: repeat(3, minmax(140px, .44fr)) minmax(260px, 1fr);\n}\n\n.metric-grid {\n  display: grid;\n  gap: 10px;\n  grid-template-columns: repeat(5, minmax(0, 1fr));\n}\n\n.metric-grid article {\n  background: #fff;\n  border: 1px solid var(--color-border);\n  border-radius: 18px;\n  box-shadow: var(--shadow-line);\n  display: grid;\n  gap: 4px;\n  padding: 9px 10px;\n}\n\n.metric-grid span,\n.muted {\n  color: var(--color-muted);\n  font-size: .78rem;\n  font-weight: 700;\n}\n\n.metric-grid span {\n  letter-spacing: .08em;\n  text-transform: uppercase;\n}\n\n.metric-grid strong {\n  color: var(--color-ink);\n  font-size: 1.55rem;\n  line-height: 1;\n}\n\n.report-layout {\n  display: grid;\n  gap: 10px;\n  grid-template-columns: minmax(0, 1fr) minmax(280px, 340px);\n}\n\n.section-head {\n  align-items: center;\n  display: flex;\n  gap: 10px;\n  justify-content: space-between;\n  margin-bottom: 12px;\n}\n\n.section-head h2,\n.gallery-card h2 {\n  font-size: 1.25rem;\n  margin-bottom: 0;\n}\n\n.access-table {\n  min-width: 980px;\n}\n\n.access-table strong,\n.access-table small {\n  display: block;\n}\n\n.access-table small {\n  color: var(--color-muted);\n  font-size: .78rem;\n}\n\n.person-count {\n  background: var(--color-brand-100);\n  border: 1px solid var(--color-brand-200);\n  border-radius: 999px;\n  color: var(--color-brand-800);\n  display: inline-flex;\n  font-weight: 700;\n  min-width: 30px;\n  padding: 4px 9px;\n}\n\n.gallery-card {\n  align-self: start;\n  display: grid;\n  gap: 10px;\n  position: sticky;\n  top: calc(var(--topbar-height) + 12px);\n}\n\n.gallery-list {\n  display: grid;\n  gap: 9px;\n  max-height: 620px;\n  overflow: auto;\n  padding-right: 2px;\n}\n\n.gallery-person {\n  align-items: center;\n  background: #f8f8f6;\n  border: 1px solid #ecece7;\n  border-radius: 18px;\n  display: grid;\n  gap: 10px;\n  grid-template-columns: 44px minmax(0, 1fr);\n  padding: 8px;\n}\n\n.gallery-photo {\n  aspect-ratio: 1;\n  background: var(--color-brand-100);\n  border: 1px solid var(--color-brand-200);\n  border-radius: 16px;\n  color: var(--color-brand-800);\n  display: grid;\n  font-weight: 700;\n  overflow: hidden;\n  place-items: center;\n}\n\n.gallery-person strong,\n.gallery-person small {\n  display: block;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.gallery-person small {\n  color: var(--color-muted);\n  font-size: .78rem;\n  font-weight: 700;\n}\n\n.loading-card {\n  color: var(--color-muted);\n}\n\n@media (max-width: 1180px) {\n  .access-head,\n  .filters-card,\n  .report-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .metric-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .gallery-card {\n    position: static;\n  }\n\n  .access-table {\n    min-width: 0;\n  }\n}\n\n@media print {\n  .topbar,\n  .filters-card,\n  .head-actions,\n  .gallery-card {\n    display: none;\n  }\n\n  .report-layout,\n  .access-head,\n  .metric-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .report-card {\n    border: 0;\n    box-shadow: none;\n  }\n}\n</style>\n"],"version":3}