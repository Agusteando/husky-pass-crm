# Password recovery email delivery. Keep these server-side only.
PASSWORD_RECOVERY_BASE_URL=http://127.0.0.1:3000
PASSWORD_RECOVERY_TOKEN_TTL_MINUTES=30
PASSWORD_RECOVERY_EMAIL_MODE=gmail
