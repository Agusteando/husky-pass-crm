GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
# Option A: escaped newlines, safe for .env files:
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-key-lines\n-----END PRIVATE KEY-----\n"
# Option B: base64-encoded private key file content. Use either Option A or B, not both.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=
GOOGLE_WORKSPACE_DELEGATED_USER=soporte@example.edu.mx
