{
  "name": "husky-pass-crm",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:production": "npm run typecheck && npm run lint && npm run build",
    "build:vercel": "vercel build --yes",
    "check:deploy-readiness": "node scripts/check-deployment-readiness.mjs",
    "preview": "nuxt preview",
    "start:output": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "smoke:deploy": "node scripts/deployment-smoke-test.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "verify:launch": "node scripts/product-visual-verify.mjs --suite launch",
    "verify:visual": "node scripts/product-visual-verify.mjs --suite all",
    "verify:journeys": "node scripts/product-visual-verify.mjs --suite journeys",
    "verify:routes": "node scripts/product-visual-verify.mjs --suite routes",
    "verify:prod": "node scripts/product-visual-verify.mjs --suite prod --production",
    "verify:identity": "node scripts/identity-visual-verify.mjs",
    "verify:husky-pass": "node scripts/husky-pass-visual-verify.mjs",
    "verify:requests": "node scripts/verify-requests.mjs",
    "verify:logs": "node scripts/verify-logs.mjs",
    "verify:mysql": "node scripts/mysql-sibling-indexes.mjs verify",
    "mysql:siblings:explain": "node scripts/mysql-sibling-indexes.mjs explain",
    "dev:password-recovery": "node scripts/password-recovery-dev.mjs",
    "dev:account-security-fixtures": "node scripts/account-security-fixtures.mjs",
    "dev:husky-pass": "nuxt dev --host 127.0.0.1 --port 3000"
