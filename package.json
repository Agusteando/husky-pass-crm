    "@sparticuz/chromium": "^149.0.0",
    "bcryptjs": "^2.4.3",
    "google-auth-library": "^9.15.1",
    "mysql2": "^3.11.5",
    "nuxt": "^3.21.8",
    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "open": "^11.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.0"
  }
